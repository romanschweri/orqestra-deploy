# Copy this file to .env and fill in real values.
# .env is ignored by git — keep secrets out of the repo.

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=orqestra
POSTGRES_PASSWORD=change-me-to-something-long-and-random
POSTGRES_DB=orqestra

# ─── Public URLs ──────────────────────────────────────────────────────────────
# What URL does the browser use to reach the API? With a reverse proxy this is
# typically https://your-domain or https://your-domain/api.
# In a plain "ports exposed on a VPS" setup, it's http://your-vps-ip:5140.
API_PUBLIC_URL=http://localhost:5140

# Where is the UI reachable from a browser? Used for CORS allow-list on the API.
UI_PUBLIC_URL=http://localhost:3000

# ─── Port mapping on the host ─────────────────────────────────────────────────
API_PORT=5140
UI_PORT=3000

# ─── Container images ─────────────────────────────────────────────────────────
# Override these if you publish your own fork to a different registry.
ORQESTRA_API_IMAGE=ghcr.io/your-github-user/orqestra-api:latest
ORQESTRA_UI_IMAGE=ghcr.io/your-github-user/orqestra-ui:latest
